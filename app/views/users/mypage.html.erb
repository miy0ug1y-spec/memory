<!-- main-visual -->
  <div class="main-visual-container mb-4">
  <%= image_tag "memory_mainvisual.webp", class: "img-fluid w-100", style: "height: 400px; object-fit: cover; object-position: center;", alt: "メインビジュアル" %>
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white w-100 px-3">
      <h1 class="display-4 fw-bold mb-3" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.6);">
        memory
      </h1>
      <p class="lead mb-0" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.6);">
        大切な人を失った人が想いを投稿するコミュニティサイト
      </p>
    </div>
  </div>  


<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
      <h5>ログインユーザー</h5>
    <div class="card w-100 mt-4">
        <div class="card-body">
         <p>@<%= link_to Current.user.handle_name, user_path(Current.user) %></p>
         <%= image_tag @user.get_profile_image(100,100), class: "img-fluid rounded-circle" %>
         <%= link_to "投稿フォーム", new_post_path, class: "btn btn-secondary" %>
         </div>
      </div>
    </div>
    

    <div class="col-md-9">
      <h5>みんなの投稿一覧</h5>

      <% @posts.each do |post| %>
        <div class="card md-3 mt-4">
          <div class="card-body">

            <% if post.within_one_week? %>
               <%= image_tag "new.jpg", size: "80x80", class:"img-fluid" %>
            <% end %>

            <div class="d-flex align-items-center mb-2">
              <%= image_tag post.user.get_profile_image(100,100), size: "70x70", class: "rounded-circle me-2" %>

              <%= link_to post.user.handle_name, user_path(post.user),class: "text-decoration-none" %>
            </div>

            <h5>
              <%= link_to post.title, post_path(post) %>
            </h5>

            <p class="post-preview">
              <%= truncate(post.body, length: 70) %>
            </p>

            <% if post.image.attached? %>
              <%= image_tag post.image, size: "250x250", class: "img-fluid" %>
            <% end %>

           <div class="d-flex justify-content-between align-items-center mt-3">
              <small class="text-muted">
                <%= post.genre&.name ||"ジャンル設定なし" %>
              </small>
              <small class="text-muted">
                <%= post.created_at.strftime("%Y年%m月%d日 %H:%M") %>
              </small>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<%= image_tag "memorisu.png", class:"character img-fluid rounded-circle" %>
 