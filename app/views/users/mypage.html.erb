<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
     
    <p>ユーザー情報</p>
      <div class="card">
        <div class="card-body">
          <p>@<%= Current.user.handle_name %></p>
          <%= image_tag @user.get_profile_image(100,100) %><br>
          <%= link_to "ユーザー編集", edit_user_path(Current.user.id) %>
        </div>
      </div>
    </div>

    <div class="col-md-9">
      <p>みんなの投稿一覧</p>
      <% @posts.each do |post| %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="row">
              <div class="col-md-2 text-center">
                <%= image_tag post.user.get_profile_image(80,80),class: "rounded-circle" %>
                <p class="mt-2">
                  <%= link_to post.user.handle_name, user_path(post.user) %>
                </p>
              </div>

              <div class="col-md-10">
                <h5>
                  <%= link_to post.title, post_path(post) %>
                </h5>
                <p>
                  <%= truncate(post.body, length: 200) %>
                </p>
                <% if post.image.attached? %>
                  <%= image_tag post.image, size: "250x250", class: "img-fluid" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>