<div class="container mt-4">
  <h5>検索結果</h5>
    <% if @search_type == "post" %>
      <p><%= @keyword %>を含む投稿</p>

      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="card mb-3">
            <div class="card-body">
              <h5>
                <%= link_to post.title, post_path(post) %>
              </h5>
              <p>
                <%= truncate(post.body, length: 100) %>
              </p>
              <small class="text-muted">
               投稿者：
               <%= link_to post.user.handle_name, user_path(post.user) %>
              </small>
            </div>
          </div>
          <% end %>
        <% else %>
          <p>該当する投稿はありません</p>
        <% end %>

      <% elsif @search_type == "user" %>
        <p><% @keyword %>を含むユーザー</p>
        <% if @users.each do |user| %>
          <div class="card mb-3">
            <div class="card-body d-flex align-items-center">
              <%= image_tag user.get_profile_image(50,50), class:"rounded-circle me-3" %>
              <%= link_to user.handle_name, user_path(user) %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p>該当するユーザーはいません</p>
      <% end %>
    <% end %>
</div>
