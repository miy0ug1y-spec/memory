<!--main-visual-->
   <div class="main-visual-container mb-4 ">
   <%= image_tag "memory_mainvisual.webp", class: "img-fluid w-100", style: "height: 400px; object-fit: cover; object-position: center;", alt: "メインビジュアル" %>
     <div class="position-absolute top-50 start-50 translate-middle text-center w-100 px-3">
    <h1 class="display-4 fw-bold mb-3" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.6);">
      memory
    </h1>
    <h5 class="lead mb-0" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.6);">
      管理者画面
    </h5>
  </div>
</div>     

<!--統計-->
<div class="container mt-4">
  <div class="row g-3 mb-4">

    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">総ユーザー数</h6>
            <p class="display-6 mb-1">
              <%= @users_count %>
            </p>
            <small class="text-muted">
              本日：<%= @today_users_count %>人
            </small>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">総投稿数</h6>
            <p class="display-6 mb-1">
              <%= @posts_count %>
            </p>
            <small class="text-muted">
              本日：<%= @today_posts_count %>件
            </small>
        </div>
      </div>
    </div>
      
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">総コメント数</h6>
            <p class="display-6 mb-1">
              <%= @comments_count %>
            </p>
            <small class="text-muted">
              本日：<%= @today_comments_count %>件
            </small>
        </div>
      </div>
    </div>
  </div>
</div>




<!--一覧-->
<div class= "container mt-4">
  <div class= "row g-4">
    <div class= "col-md-6">
      <div class="card h-100 shadow-sm">
        <div class="card-header">
          <h5 class="mb-0">ユーザ一覧</h5>
        </div>

        <div class="card-body">
        <% if @users.any? %>
        <ul class="list-group list-group-flush">
          <% @users.each do |user| %>
            <li class="list-group-item">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="mb-1 fw-bold">
                    <%= user.last_name %> 
                    <%= user.first_name %> 
                  </p>
                  <p class="mb-1 text-muted">
                    <%= user.email_address %>
                  </p>
                  <% if user.birthday.present? %>
                    <small class="text-muted">
                      生年月日：
                      <%= user.birthday.strftime("%Y年%m月%d日") %>
                    </small>
                  <% end %>
                </div>
              <%= link_to "削除", admin_user_path(user), data: {turbo_method: :delete, turbo_confirm: "このコメントを削除しますか？"}, class:"btn btn-sm btn-outline-danger" %>
              </div>
            </li>
          <% end %>
        </ul>    
        <% else %>
          <p class="text-muted">ユーザーはいません
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card h-100 shadow-sm">
      <div class="card-header">
        <h5 class="mb-0">投稿一覧</h5>
      </div>        
      <div class="card-body">
      <% if @posts.any? %>
            <ul class="list-group list-group-flush">
              <% @posts.each do |post| %>
                <li class="list-group-item">
                  <div class="d-flex justify-content-between align-items-start">
                    <div class="me-3">
                      <p class="mb-1 fw-bold">
                        <%= post.title %>
                      </p>
                      
                      <p class="mb-1">
                        <%= truncate(post.body, length: 80) %>
                      </p>

                      <small class="text-muted">
                        投稿者：
                        <%= post.user.handle_name %>
                      </small>
                    </div>

                    <%= link_to "削除", admin_post_path(post), data: {turbo_method: :delete, turbo_confirm: "この投稿を削除しますか？"}, class:"btn btn-sm btn-outline-danger" %>
                  </div>
                </li>
              <% end %>
            </ul>
            <% else %>
              <p class ="text-muted mb-0">
                投稿はありません
              </p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
   </div> 
  </div>
</div>

<div class="container mb-4">
  <div class="card shadow-sm">
    <div class="card-header">
      <h5 class="mb-0">最新コメント一覧</h5>
    </div>

    <div class="card-body">
      <% if @comments.any? %>
        <ul class="list-group list-group-flush">
        <% @comments.each do |comment| %>
          <li class="list-group-item">
            <div class="d-flex justify-content-between align-items-start">
              <div class="me-3">
                <p class="mb-1">
                  <strong><%= comment.user.handle_name %></strong>
                </p>
                <p class="mb-1">
                  <%= truncate(comment.content, length:100) %>
                </p>
                <small class="text-muted">
                  投稿：<%= comment.post.title %>/<%= comment.created_at.strftime("%Y年%m月%d日 %H:%M") %>
                </small>
              </div>
            <%= link_to "削除",admin_comment_path(comment),data: {turbo_method: :delete, turbo_confirm: "このコメントを削除しますか？"}, class: "btn btn-sm btn-outline-danger"%>
            </div>
          </li>
        <% end %>  
        </ul>
        <% else %>
        <p class="text-muted mb-0">
          コメントはありません
        </p>
      <% end %>
    </div>
  </div>
</div>
