<div class="container mt-4">
  <h5>ジャンル管理</h5>
  <div class="card mb-4">
    <div class="card-body">
      <%= form_with model: [:admin, @genre] do |f| %>
        <% if @genre.errors.any? %>
        <ul class="text-danger">
          <% @genre.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
        <% end %>
      
        <div class="mb-3">
          <%= f.label :name, "ジャンル名", class:"form-label" %>
          <%= f.text_field :name, class:"form-control" %>
        </div>
      <%= f.submit "追加", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <% @genres.each do |genre| %>
        <div class="d-flex justify-content-between align-items-center border-bottom py-2">
          <span><%= genre.name %></span>
            <div>
              <%= link_to "編集", edit_admin_genre_path(genre), class:"btn btn-sm btn-outline-primary" %>
              <%= link_to "削除", admin_genre_path(genre), data: {turbo_method: :delete, turbo_confirm:"本当に削除しますか？"}, class:"btn btn-sm btn-outline-danger" %>
            </div>
        </div>
      <% end %>
    </div>
  </div>
</div>