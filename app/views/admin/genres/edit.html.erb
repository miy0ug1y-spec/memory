<div class="containar mt-4">
  <div class="row d-flex justify-content-center">
    <div class="col-md-8">
      <h5>ジャンル管理</h5>
      <div class="card mb-4">
        <div class="card-body">
          <%= form_with model: [:admin, @genre] do |f| %>
            <div class="mb-3">
              <%= f.label :name, "ジャンル名", class:"form-label" %>
              <%= f.text_field :name, class:"form-control" %>
            </div>
            <div class="d-flex justify-content-end">
              <%= f.submit "更新", class:"btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
      <%= link_to "＜  戻る", admin_genres_path %>
    </div>
  </div>
</div>
