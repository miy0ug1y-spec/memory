<div class="containar mt-4">
  <h5>ジャンル管理</h5>
  <div class="card mb-4">
    <div class="card-body">
      <%= form_with model: [:admin, @genre] do |f| %>
        <div class="mb-3">
          <%= f.label :name, "ジャンル名", class:"form-label" %>
          <%= f.text_field :name, class:"form-control" %>
        </div>
        <%= f.submit "更新", class:"btn btn-primary" %>
      <% end %>
    </div>
  </div>

  </div>
</div>