<h1>編集画面</h1>
<% if @post.errors.any? %>
  <ul>
    <% @post.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @post do |f| %>

  <h4>タイトル</h4>
  <%= f.text_field :title %>
  
  <h4>本文</h4>
  <%= f.text_area :body %>

  <h4>画像</h4>
  <% if @post.image.attached? %>
    <%= image_tag @post.image, size: "200x200" %>
  <% end %>

  <%= f.file_field :image %><br>

  <%= f.submit '保存' %>
  <%= link_to "削除", post_path(@post),  data: { turbo_method: :delete, turbo_confirm: "本当に削除？" } %>

<% end %>